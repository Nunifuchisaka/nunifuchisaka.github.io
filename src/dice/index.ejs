<!doctype html>
<html lang="ja">
<head><%
const path = "../";
const meta = {
  title: "話題サイコロ",
  description: "VRChatでの雑談中に話題を迷ったときにランダムに話題を選んでくれるサイコロ",
  url: "dice/",
  titleSeparator: " | ",
};
%>
<%- include(path + "assets/html/_head",{meta:meta}) %>
<link rel="stylesheet" href="/dice/dice.css">
</head>
<body>
<%- include(path + "assets/html/_body_before") %>

<div id="wrapper">
<%- include(path + "assets/html/_header") %>

<main id="main">
<header class="header_3">
  <h2 class="header_3__h1">
    話題サイコロ
  </h2>
</header><!-- /.header_3 -->

<div class="dice_1">
  <p class="dice_1__lead">
    話題に迷ったら、ボタンを押してみよう。
  </p>
  <button type="button" class="dice_1__button" id="js-dice-button">
    <i class="fa-solid fa-dice dice_1__icon" id="js-dice-icon" aria-hidden="true"></i>
    <span>サイコロを振る</span>
  </button>
  <div class="dice_1__result" id="js-dice-result" aria-live="polite">
    <p class="dice_1__question" id="js-dice-question">
      ボタンを押すと話題が表示されます
    </p>
    <p class="dice_1__example" id="js-dice-example"></p>
  </div>
</div><!-- /.dice_1 -->
</main><!-- /#main -->

<%- include(path + "assets/html/_footer") %>
</div><!-- /#wrapper -->

<%- include(path + "assets/html/_body_after") %>
<script src="/dice/dice.js" defer></script>
</body>
</html>
