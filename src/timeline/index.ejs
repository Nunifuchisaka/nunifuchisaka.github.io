<!doctype html>
<html lang="ja">
<head><%
const path = "../";
const meta = {
  title: "案内実績",
  description: "VRChatを始めるお手伝いをしてきた案内実績・タイムライン",
};
%>
<%- include(path + "assets/html/_head",{meta:meta}) %>
</head>
<body>
<%- include(path + "assets/html/_body_before") %>

<div id="wrapper">
<%- include(path + "assets/html/_header") %>

<header class="header_3">
  <h1 class="header_3__h1">
    案内実績
  </h1>
</header><!-- /.header_3 -->

<p>
  「#VRChat始めました」の報告をもとに集計した、VRChatを始めるお手伝いをしてきた記録です。
</p>

<ul class="list_5">
  <li>
    累計案内人数: <%= guideStats.total %>人
  </li>
  <li>
    活動開始日: <%= guideStats.firstDate %>
  </li>
  <li>
    直近の案内日: <%= guideStats.lastDate %>
  </li>
</ul><!-- /.list_5 -->

<header class="header_3">
  <h1 class="header_3__h1">
    マイルストーン
  </h1>
</header><!-- /.header_3 -->

<ul class="list_5">
  <% guideStats.milestones.forEach(function (milestone) { %>
    <li>
      <%= milestone.count %>人目: <%= milestone.date %>
    </li>
  <% }); %>
</ul><!-- /.list_5 -->

<p>
  <a href="/#guide">写真をすべて見る</a>
</p>

<%- include(path + "assets/html/_footer") %>
</div><!-- /#wrapper -->

<%- include(path + "assets/html/_body_after") %>
</body>
</html>
